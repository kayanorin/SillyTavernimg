export const Schema = z.object({
    场景: z.object({
        当前区域: z.string().prefault('未设定'),
        时间: z.string().prefault('深夜 11:30'),
        天气与环境: z.string().prefault('未设定'),
        区域状态: z.record(z.string().describe('区域名'), z.object({
            描述: z.string(),
            可通行: z.boolean(),
            危险等级: z.coerce.number().transform(v => _.clamp(v, 0, 5)),
            已探索: z.boolean(),
        })).prefault({}),
        逃生进度: z.record(z.string().describe('逃生条件名'), z.object({
            描述: z.string(),
            是否达成: z.boolean(),
        })).prefault({}),
    }),
    角色: z.record(z.string().describe('角色名'), z.object({
        _性别: z.enum(['女', '男']),
        _外貌: z.string(),
        _性格核心: z.string(),
        _性格标签: z.string(),
        _弱点: z.string(),
        _来源: z.string().prefault('原创'),
        _特殊能力: z.string().prefault('普通人'),
        状态: z.enum(['存活', '重伤', '濒死', '死亡', '失踪']),
        当前位置: z.string(),
        着装: z.string(),
        恐惧: z.coerce.number().transform(v => _.clamp(v, 0, 100)),
        理智: z.coerce.number().transform(v => _.clamp(v, 0, 100)),
        体力: z.coerce.number().transform(v => _.clamp(v, 0, 100)),
        对user的信任: z.coerce.number().transform(v => _.clamp(v, -100, 100)),
        当前行为: z.string(),
        内心状态: z.string(),
        伤势: z.string(),
        持有物品: z.record(z.string().describe('物品名'), z.string()).prefault({}),
    })).prefault({}),
    追击者: z.object({
        当前位置: z.string().prefault('未设定'),
        伪装身份: z.string().nullable().prefault(null),
        暴露程度: z.coerce.number().transform(v => _.clamp(v, 0, 100)).prefault(0),
        威胁手段: z.record(z.string().describe('手段名'), z.object({
            描述: z.string(),
            类型: z.enum(['物理', '心理', '环境', '超自然']),
        })).prefault({}),
        已造成的效果: z.string().prefault('尚未行动'),
    }),
    事件: z.object({
        阶段: z.coerce.number().transform(v => _.clamp(v, 1, 5)).prefault(1),
        阶段描述: z.string().prefault('探索期'),
        死亡记录: z.record(z.string().describe('角色名'), z.object({
            死因: z.string(),
            场景: z.string(),
        })).prefault({}),
        关键事件: z.record(z.string().describe('事件名'), z.object({
            描述: z.string(),
            $time: z.coerce.number().prefault(() => Date.now()),
        })).transform(obj => _(obj).entries().sortBy(([_, v]) => v.$time).takeRight(10).fromPairs().value()).prefault({}),
    }),
    氛围: z.object({
        恐怖等级: z.coerce.number().transform(v => _.clamp(v, 1, 10)).prefault(2),
        异常现象: z.string().prefault('一切看似正常'),
        线索碎片: z.record(z.string().describe('线索名'), z.object({
            内容: z.string(),
            发现者: z.string(),
        })).prefault({}),
    }),
});
